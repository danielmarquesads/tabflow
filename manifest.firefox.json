{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.1",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "permissions": ["tabs", "storage", "alarms", "contextMenus"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "scripts": ["src/background/service-worker.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-pause": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "__MSG_cmdTogglePause__"
    },
    "keep-tab": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "Alt+Shift+K"
      },
      "description": "__MSG_cmdKeepTab__"
    },
    "snooze-tab": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "__MSG_cmdSnoozeTab__"
    },
    "open-archive": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "__MSG_cmdOpenArchive__"
    },
    "open-options": {
      "description": "__MSG_cmdOpenOptions__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/activity.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/fab.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tabflow@open-source.local",
      "strict_min_version": "115.0"
    }
  }
}
